{
  "expo": {
    "name": "كليم",
    "slug": "kaleem-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kaleem",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#007A68"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kaleemai.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#007A68"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kaleemai.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "السماح لكليم بالوصول إلى صورك لتحديث الصورة الشخصية."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://api.kaleemai.com/api",
      "useMock": false,
      "router": {},
      "eas": {
        "projectId": "39e8033b-c842-4e00-8ae3-f8087b85aca2"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "ibrahim-hassan",
    "updates": {
      "url": "https://u.expo.dev/39e8033b-c842-4e00-8ae3-f8087b85aca2"
    }
  }
}
